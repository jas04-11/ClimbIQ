    # ── Board drawing ──────────────────────────────────────────────────────
    def _draw_board(self):
        c = self.board_canvas
        for cell in range(1, 101):
            r, col = cell_to_rc(cell)
            x0 = col * CELL
            y0 = r   * CELL
            fill = CELL_A if (r + col) % 2 == 0 else CELL_B
            # Highlight special cells
            if cell in SNAKES:
                fill = "#2a1a1e"
            elif cell in LADDERS:
                fill = "#1a2a1e"
            c.create_rectangle(x0, y0, x0+CELL, y0+CELL,
                                fill=fill, outline=GRID_LINE, width=1)
            # Cell number
            num_x = x0 + 6
            num_y = y0 + 5
            num_color = "#ff4757" if cell in SNAKES else \
                        "#2ed573" if cell in LADDERS else TEXT_DIM
            c.create_text(num_x, num_y, text=str(cell), anchor="nw",
                          font=("Courier", 8, "bold"), fill=num_color)

        # Row labels (10,20,...100 on the side)
        for row in range(BOARD_SIZE):
            visual_row = BOARD_SIZE - 1 - row
            row_start = row * BOARD_SIZE + 1
            # draw subtle row stripe guide
            pass

    def _draw_snakes(self):
        c = self.board_canvas
        for head, tail in SNAKES.items():
            x1, y1 = cell_xy(head)
            x2, y2 = cell_xy(tail)
            # Draw a wavy snake body
            col_idx = list(SNAKES.keys()).index(head) % len(SNAKE_C)
            color = SNAKE_C[col_idx]
            # Control points for curve
            mx = (x1 + x2) / 2 + random.choice([-40, 40])
            my = (y1 + y2) / 2 + random.choice([-30, 30])
            # Smooth bezier-like with segments
            pts = []
            for t in [i/20 for i in range(21)]:
                bx = (1-t)**2*x1 + 2*(1-t)*t*mx + t**2*x2
                by = (1-t)**2*y1 + 2*(1-t)*t*my + t**2*y2
                pts.extend([bx, by])
            c.create_line(pts, fill=color, width=7, smooth=True,
                          joinstyle=tk.ROUND, capstyle=tk.ROUND)
            c.create_line(pts, fill=self._lighten(color), width=3,
                          smooth=True, joinstyle=tk.ROUND)
            # Snake head
            c.create_oval(x1-12, y1-12, x1+12, y1+12,
                          fill=color, outline=self._lighten(color), width=2)
            c.create_text(x1, y1, text="🐍", font=("Arial", 14))
            # Tail dot
            c.create_oval(x2-5, y2-5, x2+5, y2+5, fill=color, outline="")

    def _draw_ladders(self):
        c = self.board_canvas
        for bottom, top in LADDERS.items():
            x1, y1 = cell_xy(bottom)
            x2, y2 = cell_xy(top)
            col_idx = list(LADDERS.keys()).index(bottom) % len(LADDER_C)
            color = LADDER_C[col_idx]
            # Side rails
            angle = math.atan2(y2 - y1, x2 - x1)
            perp  = angle + math.pi / 2
            off   = 7
            for sign in [-1, 1]:
                rx1 = x1 + sign * off * math.cos(perp)
                ry1 = y1 + sign * off * math.sin(perp)
                rx2 = x2 + sign * off * math.cos(perp)
                ry2 = y2 + sign * off * math.sin(perp)
                c.create_line(rx1, ry1, rx2, ry2, fill=color, width=4,
                              capstyle=tk.ROUND)
            # Rungs
            dist = math.hypot(x2-x1, y2-y1)
            steps = max(2, int(dist // 22))
            for i in range(1, steps):
                t   = i / steps
                rx  = lerp(x1, x2, t)
                ry  = lerp(y1, y2, t)
                r1x = rx + off * math.cos(perp)
                r1y = ry + off * math.sin(perp)
                r2x = rx - off * math.cos(perp)
                r2y = ry - off * math.sin(perp)
                c.create_line(r1x, r1y, r2x, r2y, fill=color, width=3,
                              capstyle=tk.ROUND)
            # Icons
            c.create_text(x1, y1, text="⬆", font=("Arial", 13), fill=color)
            c.create_text(x2, y2, text="🏆", font=("Arial", 12))

    def _lighten(self, hex_color):
        r = int(hex_color[1:3], 16)
        g = int(hex_color[3:5], 16)
        b = int(hex_color[5:7], 16)
        r = min(255, r + 60)
        g = min(255, g + 60)
        b = min(255, b + 60)
        return f"#{r:02x}{g:02x}{b:02x}"

    # ── Token drawing ──────────────────────────────────────────────────────
    def _draw_tokens(self):
        c = self.board_canvas
        c.delete("token")
        c.delete("token_glow")

        # Human token (cyan circle with "YOU")
        if self.human_pos > 0:
            x, y = cell_xy(self.human_pos, offset_x=-12)
            # Glow
            c.create_oval(x-18, y-18, x+18, y+18,
                          fill="", outline=ACCENT1, width=2,
                          tags="token_glow")
            c.create_oval(x-13, y-13, x+13, y+13,
                          fill=ACCENT1, outline="white", width=2,
                          tags="token")
            c.create_text(x, y, text="YOU", font=("Courier", 6, "bold"),
                          fill="#0d1117", tags="token")

        # AI token (coral circle with "AI")
        if self.ai_pos > 0:
            offset = 12 if self.ai_pos != self.human_pos else 12
            x, y = cell_xy(self.ai_pos, offset_x=offset if self.ai_pos != self.human_pos else 12)
            # Glow
            c.create_oval(x-18, y-18, x+18, y+18,
                          fill="", outline=ACCENT2, width=2,
                          tags="token_glow")
            c.create_oval(x-13, y-13, x+13, y+13,
                          fill=ACCENT2, outline="white", width=2,
                          tags="token")
            c.create_text(x, y, text="AI", font=("Courier", 7, "bold"),
                          fill="white", tags="token")

    # ── Dice ───────────────────────────────────────────────────────────────
    DICE_DOTS = {
        1: [(45, 45)],
        2: [(25, 25), (65, 65)],
        3: [(20, 20), (45, 45), (70, 70)],
        4: [(22, 22), (68, 22), (22, 68), (68, 68)],
        5: [(22, 22), (68, 22), (45, 45), (22, 68), (68, 68)],
        6: [(22, 20), (68, 20), (22, 45), (68, 45), (22, 70), (68, 70)],
    }

    def _draw_dice_face(self, val):
        c = self.dice_canvas
        c.delete("all")
        c.create_rectangle(4, 4, 86, 86, fill=DICE_BG, outline=ACCENT1,
                           width=2)
        if val == 0:
            c.create_text(45, 45, text="?", fill=TEXT_DIM,
                          font=("Courier", 32, "bold"))
            return
        for (dx, dy) in self.DICE_DOTS[val]:
            c.create_oval(dx-7, dy-7, dx+7, dy+7,
                          fill=DICE_FG, outline="")

    def _animate_dice(self, final_val, steps=10, callback=None):
        if steps <= 0:
            self._draw_dice_face(final_val)
            if callback:
                self.root.after(200, callback)
            return
        self._draw_dice_face(random.randint(1, 6))
        delay = max(40, 200 - (10 - steps) * 16)
        self.root.after(delay, lambda: self._animate_dice(
            final_val, steps - 1, callback))

    # ── Token animation ────────────────────────────────────────────────────
    def _animate_token_move(self, is_human, start, end, callback=None):
        """Step-by-step token animation from start to end."""
        if start == end:
            self._draw_tokens()
            if callback: callback()
            return

        direction = 1 if end > start else -1
        path = list(range(start, end + direction, direction))

        def step(idx):
            if idx >= len(path):
                self._draw_tokens()
                self.root.after(200, callback if callback else lambda: None)
                return
            pos = path[idx]
            if is_human:
                self.human_pos = pos
            else:
                self.ai_pos = pos
            self._draw_tokens()
            self.root.after(80, lambda: step(idx + 1))

        step(0)

    # ── Panel update ───────────────────────────────────────────────────────
    def _update_panel(self):
        self.human_pos_lbl.config(text=str(self.human_pos))
        self.ai_pos_lbl.config(text=str(self.ai_pos))

        # Status labels
        hs = ""
        if self.human_pos in SNAKES: hs = "🐍 bitten!"
        elif self.human_pos in LADDERS: hs = "🪜 climbed!"
        elif self.human_pos == 100: hs = "🏆 winner!"
        self.human_status.config(text=hs)

        as_ = ""
        if self.ai_pos in SNAKES: as_ = "🐍 bitten!"
        elif self.ai_pos in LADDERS: as_ = "🪜 climbed!"
        elif self.ai_pos == 100: as_ = "🏆 winner!"
        self.ai_status.config(text=as_)

        if not self.game_over:
            if self.human_turn:
                self.turn_lbl.config(text="YOUR TURN ►", fg=ACCENT1)
                self.dice_canvas.config(highlightbackground=ACCENT1)
                self.roll_btn.config(state=tk.NORMAL, bg=ACCENT1)
            else:
                self.turn_lbl.config(text="◄ AI THINKING", fg=ACCENT2)
                self.dice_canvas.config(highlightbackground=ACCENT2)
                self.roll_btn.config(state=tk.DISABLED, bg=CELL_B)

    def _log(self, msg, tag=""):
        self.log_box.config(state=tk.NORMAL)
        self.log_box.insert(tk.END, msg + "\n", tag)
        self.log_box.see(tk.END)
        self.log_box.config(state=tk.DISABLED)

    def _set_coord(self, msg):
        self.coord_lbl.config(text=msg)

    # ── Human turn ─────────────────────────────────────────────────────────
    def _human_roll(self):
        if self.game_over or self.rolling or not self.human_turn:
            return
        self.rolling = True
        self.roll_btn.config(state=tk.DISABLED)
        dice = random.randint(1, 6)
        self._animate_dice(dice, callback=lambda: self._human_move(dice))

    def _human_move(self, dice):
        old_pos = self.human_pos
        new_pos = min(self.human_pos + dice, 100)

        self._log(f"► You rolled {dice}", "player")
        self._set_coord(f"You rolled {dice}  |  {old_pos} → {new_pos}")

        def after_move():
            actual = board_result(self.human_pos)
            if actual != self.human_pos:
                old = self.human_pos
                if actual < old:
                    self._log(f"  🐍 Snake! {old} → {actual}", "snake")
                    self._set_coord(f"🐍 Snake bites! {old} → {actual}")
                else:
                    self._log(f"  🪜 Ladder! {old} → {actual}", "ladder")
                    self._set_coord(f"🪜 Ladder climb! {old} → {actual}")
                self._animate_token_move(True, old, actual,
                                         callback=self._after_human)
                self.human_pos = actual
            else:
                self._after_human()

        self._animate_token_move(True, old_pos, new_pos, callback=after_move)
        self.human_pos = new_pos
        self._update_panel()

    def _after_human(self):
        self._draw_tokens()
        self._update_panel()
        if self.human_pos >= 100:
            self.human_pos = 100
            self._win("YOU")
            return
        self.human_turn = False
        self.rolling    = False
        self._update_panel()
        self.root.after(700, self._ai_turn)

    # ── AI turn ────────────────────────────────────────────────────────────
    def _ai_turn(self):
        if self.game_over:
            return
        # Minimax picks best dice – but we simulate a real roll influenced by AI strategy
        best = ai_best_roll(self.ai_pos, self.human_pos)
        # To keep it fair (AI can't control real dice), we roll randomly but
        # show which value minimax would prefer.  For a stronger "AI" feel we
        # bias toward the best roll 50% of time:
        if random.random() < 0.5:
            dice = best
        else:
            dice = random.randint(1, 6)

        self._log(f"◄ AI rolled {dice}", "ai")
        self._animate_dice(dice, callback=lambda: self._ai_move(dice))

    def _ai_move(self, dice):
        old_pos = self.ai_pos
        new_pos = min(self.ai_pos + dice, 100)
        self._set_coord(f"AI rolled {dice}  |  {old_pos} → {new_pos}")

        def after_move():
            actual = board_result(self.ai_pos)
            if actual != self.ai_pos:
                old = self.ai_pos
                if actual < old:
                    self._log(f"  🐍 Snake! {old} → {actual}", "snake")
                    self._set_coord(f"AI: 🐍 Snake bites! {old} → {actual}")
                else:
                    self._log(f"  🪜 Ladder! {old} → {actual}", "ladder")
                    self._set_coord(f"AI: 🪜 Ladder! {old} → {actual}")
                self._animate_token_move(False, old, actual,
                                         callback=self._after_ai)
                self.ai_pos = actual
            else:
                self._after_ai()

        self._animate_token_move(False, old_pos, new_pos, callback=after_move)
        self.ai_pos = new_pos
        self._update_panel()

    def _after_ai(self):
        self._draw_tokens()
        self._update_panel()
        if self.ai_pos >= 100:
            self.ai_pos = 100
            self._win("AI")
            return
        self.human_turn = True
        self.rolling    = False
        self._update_panel()

    # ── Win ────────────────────────────────────────────────────────────────
    def _win(self, who):
        self.game_over = True
        self._draw_tokens()
        if who == "YOU":
            msg = "🏆 YOU WIN! 🏆"
            color = ACCENT1
            self._log("★ YOU WIN! Congratulations!", "win")
        else:
            msg = "🤖 AI WINS!"
            color = ACCENT2
            self._log("★ AI WINS! Better luck next time.", "win")
        self.turn_lbl.config(text=msg, fg=color)
        self.roll_btn.config(state=tk.DISABLED, text="GAME OVER", bg=CELL_B)
        self._set_coord(msg)
        # Flash the winning cell
        self._flash_win(color)

    def _flash_win(self, color, times=6):
        if times <= 0: return
        self.board_canvas.delete("win_flash")
        if times % 2 == 0:
            pos = self.human_pos if color == ACCENT1 else self.ai_pos
            x, y = cell_xy(pos)
            self.board_canvas.create_oval(
                x-25, y-25, x+25, y+25,
                outline=color, width=4, tags="win_flash")
        self.root.after(250, lambda: self._flash_win(color, times - 1))

    # ── New game ───────────────────────────────────────────────────────────
    def _new_game(self):
        self.human_pos  = 0
        self.ai_pos     = 0
        self.human_turn = True
        self.game_over  = False
        self.rolling    = False
        self.dice_val   = 0
        self.board_canvas.delete("token")
        self.board_canvas.delete("token_glow")
        self.board_canvas.delete("win_flash")
        self._draw_dice_face(0)
        self.log_box.config(state=tk.NORMAL)
        self.log_box.delete("1.0", tk.END)
        self.log_box.config(state=tk.DISABLED)
        self.roll_btn.config(text="🎲  ROLL DICE", bg=ACCENT1, state=tk.NORMAL)
        self._update_panel()
        self._set_coord("New game started! Roll the dice.")
        self._log("── New Game Started ──", "win")


