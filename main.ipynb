import tkinter as tk
from tkinter import font as tkfont
import random
import math
import time

# ─────────────────────────────────────────────────────────────────────────────
#  BOARD DATA
# ─────────────────────────────────────────────────────────────────────────────
SNAKES = {
    97: 78, 95: 56, 88: 24, 72: 51, 62: 18,
    49: 11, 46: 25, 37: 3,  36: 6,  17: 7
}
LADDERS = {
    4: 14,  9: 31,  20: 38, 28: 84, 40: 59,
    51: 67, 63: 81, 71: 91, 80: 99
}

BOARD_SIZE = 10
CELL       = 70        # px per cell
BOARD_PX   = BOARD_SIZE * CELL  # 700
PANEL_W    = 320
WIN_W      = BOARD_PX + PANEL_W
WIN_H      = BOARD_PX + 60

# Colour palette – deep jungle night
BG          = "#0d1117"
PANEL_BG    = "#161b22"
ACCENT1     = "#00e5a0"   # neon mint (player)
ACCENT2     = "#ff6b6b"   # coral (AI)
GOLD        = "#ffd700"
CELL_A      = "#1a2332"
CELL_B      = "#1e2a3a"
GRID_LINE   = "#263040"
SNAKE_C     = ["#ff4757","#ff6348","#ff7f50"]
LADDER_C    = ["#2ed573","#7bed9f","#00e5a0"]
TEXT_LIGHT  = "#e8f4fd"
TEXT_DIM    = "#8892a4"
DICE_BG     = "#1e2a3a"
DICE_FG     = "#ffffff"

MINIMAX_DEPTH = 3

# ─────────────────────────────────────────────────────────────────────────────
#  MINIMAX
# ─────────────────────────────────────────────────────────────────────────────
def board_result(pos):
    if pos in SNAKES:  return SNAKES[pos]
    if pos in LADDERS: return LADDERS[pos]
    return pos

def minimax(ai_pos, human_pos, depth, is_ai_turn, alpha, beta):
    if ai_pos >= 100:
        return 1000 + depth
    if human_pos >= 100:
        return -1000 - depth
    if depth == 0:
        return ai_pos - human_pos

    if is_ai_turn:
        best = -math.inf
        for d in range(1, 7):
            new_ai = board_result(min(ai_pos + d, 100))
            if new_ai >= 100:
                val = 1000 + depth
            else:
                val = minimax(new_ai, human_pos, depth - 1, False, alpha, beta)
            best = max(best, val)
            alpha = max(alpha, best)
            if beta <= alpha:
                break
        return best
    else:
        best = math.inf
        for d in range(1, 7):
            new_human = board_result(min(human_pos + d, 100))
            if new_human >= 100:
                val = -1000 - depth
            else:
                val = minimax(ai_pos, new_human, depth - 1, True, alpha, beta)
            best = min(best, val)
            beta = min(beta, best)
            if beta <= alpha:
                break
        return best

def ai_best_roll(ai_pos, human_pos):
    """Return the dice value (1-6) that maximises AI score."""
    best_val  = -math.inf
    best_dice = 1
    for d in range(1, 7):
        new_ai = board_result(min(ai_pos + d, 100))
        if new_ai >= 100:
            return d   # winning move – take it immediately
        val = minimax(new_ai, human_pos, MINIMAX_DEPTH - 1, False,
                      -math.inf, math.inf)
        if val > best_val:
            best_val, best_dice = val, d
    return best_dice

# ─────────────────────────────────────────────────────────────────────────────
#  HELPERS
# ─────────────────────────────────────────────────────────────────────────────
def cell_to_rc(cell):
    """Convert 1-100 cell number to (row, col) where row 0 = top."""
    cell  -= 1                      # 0-based
    row   = cell // BOARD_SIZE
    col   = cell  % BOARD_SIZE
    # even rows go left-to-right, odd rows right-to-left
    visual_row = (BOARD_SIZE - 1) - row
    if row % 2 == 1:                # odd row (0-based) → reversed
        col = (BOARD_SIZE - 1) - col
    return visual_row, col

def cell_xy(cell, offset_x=0, offset_y=0):
    """Centre pixel of cell on the board canvas."""
    r, c = cell_to_rc(cell)
    x = c * CELL + CELL // 2 + offset_x
    y = r * CELL + CELL // 2 + offset_y
    return x, y

def lerp(a, b, t):
    return a + (b - a) * t

# ─────────────────────────────────────────────────────────────────────────────
#  MAIN APP
# ─────────────────────────────────────────────────────────────────────────────
class SnakeLadderApp:
    def __init__(self, root):
        self.root = root
        self.root.title("🐍 ClimbIQ: Snake & Ladder")
        self.root.configure(bg=BG)
        self.root.resizable(False, False)

        # Game state
        self.human_pos   = 0
        self.ai_pos      = 0
        self.human_turn  = True
        self.game_over   = False
        self.rolling     = False
        self.dice_val    = 0
        self.move_history = []   # list of strings

        # Animation state
        self._anim_id    = None
        self._bounce_ids = []

        self._build_window()
        self._draw_board()
        self._draw_snakes()
        self._draw_ladders()
        self._draw_tokens()
        self._update_panel()

