            self.root, width=BOARD_PX, height=BOARD_PX,
            bg=BG, highlightthickness=0)
        self.board_canvas.place(x=0, y=0)

        # Bottom strip under board
        foot = tk.Frame(self.root, bg=BG, height=60, width=BOARD_PX)
        foot.place(x=0, y=BOARD_PX)
        self.coord_lbl = tk.Label(
            foot, text="Roll the dice to start!",
            bg=BG, fg=TEXT_DIM, font=("Courier", 11))
        self.coord_lbl.pack(pady=18)

        # Right panel
        panel = tk.Frame(self.root, bg=PANEL_BG, width=PANEL_W, height=WIN_H)
        panel.place(x=BOARD_PX, y=0)
        panel.pack_propagate(False)

        self._build_panel(panel)

